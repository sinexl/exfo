extern "C" func memcmp(int*, int*, int): int;
extern "C" func printf(char_ptr, ...): void;

func get_string(a: bool): char_ptr {
    if a  return "true";
    else  return "false";
}

func test_ordering(): void {
    True := true;
    False := false;
    size := 8;

    i := -1; while i <= 1 {
        j := -1; while j <= 1 {
            le  := i < j;
            ge  := i > j;
            leq := i <= j;
            geq := i >= j;

            printf("< --- (i, j) = (%d, %d) --- >%c", i, j, 10);
            printf("%3d <  %3d: %5s\n", i, j, get_string(le));
            printf("%3d >  %3d: %5s\n", i, j, get_string(ge));
            printf("%3d <= %3d: %5s\n", i, j, get_string(leq));
            printf("%3d >= %3d: %5s\n", i, j, get_string(geq));
            j = j + 1;
        }
        i = i + 1;
    }
}

func main(): int {
    test_ordering();

    return 0;
}
